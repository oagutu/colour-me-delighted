{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "colour-me-delighted",
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "entry": "splash.html"
      },
      "game": {
        "entry": "game.html"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "menu": {
    "items": [
      {
        "label": "Create a new post",
        "description": "colour-me-delighted",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/post-create"
      },
      {
        "label": "Daily Image Upload form",
        "description": "Daily image creation Form",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/daily-image-create"
      }
    ]
  },
  "permissions": {
    "reddit": {
      "asUser": ["SUBMIT_COMMENT"]
    },
    "media": true,
    "redis": true
  },
  "forms": {
    "dailyImageForm": "/internal/form/daily-image-submit"
  },
  "triggers": {
    "onAppInstall": "/internal/triggers/on-app-install"
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build"
  },
  "dev": {
    "subreddit": "colour_me_delight_dev"
  }
}